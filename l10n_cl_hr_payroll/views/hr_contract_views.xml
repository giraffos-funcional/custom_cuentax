<odoo>

    <record id="hr_contract_view_form_inherit_l10n_cl" model="ir.ui.view">
        <field name="name">hr.contract.form.inherit.l10n_cl</field>
        <field name="model">hr.contract</field>
        <field name="inherit_id" ref="hr_contract.hr_contract_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='wage']" position="after">
                <field name="l10n_cl_contract_type"/>
                <field name="l10n_cl_gratificacion_type"/>
                <field name="l10n_cl_colacion"/>
                <field name="l10n_cl_movilizacion"/>
            </xpath>
        </field>
    </record>

</odoo>
