<odoo>
    <data noupdate="0">

        <!-- Chilean salary rule categories -->
        <record id="cl_categ_basic" model="hr.salary.rule.category">
            <field name="name">Sueldo Base</field>
            <field name="code">BASIC</field>
        </record>

        <record id="cl_categ_alw" model="hr.salary.rule.category">
            <field name="name">Asignaciones / Haberes</field>
            <field name="code">ALW</field>
        </record>

        <record id="cl_categ_alwnotimp" model="hr.salary.rule.category">
            <field name="name">Haberes No Imponibles</field>
            <field name="code">ALWNOTIMP</field>
        </record>

        <record id="cl_categ_ded" model="hr.salary.rule.category">
            <field name="name">Deducciones</field>
            <field name="code">DED</field>
        </record>

        <record id="cl_categ_dedprev" model="hr.salary.rule.category">
            <field name="name">Deducciones Previsionales</field>
            <field name="code">DEDPREV</field>
        </record>

        <record id="cl_categ_dedsalud" model="hr.salary.rule.category">
            <field name="name">Deducciones de Salud</field>
            <field name="code">DEDSALUD</field>
        </record>

        <record id="cl_categ_dedtrib" model="hr.salary.rule.category">
            <field name="name">Deducciones Tributarias</field>
            <field name="code">DEDTRIB</field>
        </record>

        <record id="cl_categ_gross" model="hr.salary.rule.category">
            <field name="name">Total Imponible / Bruto</field>
            <field name="code">GROSS</field>
        </record>

        <record id="cl_categ_net" model="hr.salary.rule.category">
            <field name="name">Sueldo Líquido</field>
            <field name="code">NET</field>
        </record>

        <record id="cl_categ_comp" model="hr.salary.rule.category">
            <field name="name">Costo Empresa</field>
            <field name="code">COMP</field>
        </record>

    </data>
</odoo>
