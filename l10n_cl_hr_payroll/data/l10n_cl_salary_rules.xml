            <field name="condition_select">none</field>
            <field name="amount_select">code</field>
            <field name="amount_python_compute">
result = round(categories['GROSS'] * 0.0093)
            </field>
        </record>

        <!-- 20. COSTOEMP - Costo Empresa Total (seq 130) -->
        <record id="cl_rule_costoemp" model="hr.salary.rule">
            <field name="name">Costo Empresa Total</field>
