<odoo>
    <data noupdate="1">

        <!-- Record rules: multi-company isolation for indicators -->
        <record id="l10n_cl_indicators_company_rule" model="ir.rule">
            <field name="name">Indicadores Chile: multi-company</field>
            <field name="model_id" ref="model_l10n_cl_indicators"/>
            <field name="domain_force">[
                '|',
                ('company_id', '=', False),
                ('company_id', 'in', company_ids),
            ]</field>
        </record>

    </data>
</odoo>
